    "knowledgePoints": ["multi-digit-multiplication", "word-problem-2"],
    "difficulty": 3,
    "errorProne": ["乘加顺序混淆"],
    "slots": {
      "person": { "type": "pick", "values": ["小明", "小红", "小刚", "小丽", "聪聪"] },
      "book": { "type": "pick", "values": ["《童话故事》", "《数学趣题》", "《科学探秘》", "《历史故事》"] },
      "a": { "type": "range", "min": 5, "max": 18 },
      "b": { "type": "range", "min": 3, "max": 9 },
      "c": { "type": "range", "min": 10, "max": 50 }
