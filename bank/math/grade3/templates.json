[
  {
    "id": "g3-t-001",
    "type": "application",
    "template": "{person}去超市买了{a}千克{stuff}，每千克{b}元，又买了{c}千克{fruit}，每千克{d}元。{person}一共花了多少钱？",
    "knowledgePoints": ["multi-digit-multiplication", "decimal-life", "word-problem-2"],
    "difficulty": 3,
    "errorProne": ["两步混淆", "单位遗漏"],
    "slots": {
      "person": { "type": "pick", "values": ["小明", "小红", "小刚", "小丽", "华华", "乐乐"] },
      "stuff": { "type": "pick", "values": ["苹果", "梨", "香蕉", "橙子"] },
      "fruit": { "type": "pick", "values": ["橘子", "西瓜", "桃子", "葡萄", "草莓"] },
      "a": { "type": "range", "min": 2, "max": 9 },
      "b": { "type": "range", "min": 3, "max": 8 },
      "c": { "type": "range", "min": 1, "max": 7 },
      "d": { "type": "range", "min": 3, "max": 8 }
    },
    "constraints": [
      { "check": "a !== c || b !== d", "msg": "两组数据应有差异，增加区分度" },
      { "check": "a * b <= 72", "msg": "第一组总价合理" },
      { "check": "a * b + c * d <= 120", "msg": "总价不超过120元" }
    ],
    "answer": {
      "type": "steps",
      "unit": "元",
      "steps": [
        { "label": "{stuff}总价", "expr": "a * b", "unit": "元" },
        { "label": "{fruit}总价", "expr": "c * d", "unit": "元" },
        { "label": "一共花的钱", "expr": "a * b + c * d", "unit": "元" }
      ]
    },
    "source": "21世纪教育网·三下·两位数乘法应用题"
  },
  {
    "id": "g3-t-002",
    "type": "application",
    "template": "{person}买了{a}本笔记本，每本{b}元，又买了{c}支笔，每支{d}元。付了{money}元，应找回多少元？",
    "knowledgePoints": ["multi-digit-multiplication", "decimal-life", "word-problem-2"],
    "difficulty": 4,
    "errorProne": ["三步混淆", "找零计算"],
    "slots": {
      "person": { "type": "pick", "values": ["小明", "小红", "小刚", "小丽", "华华", "乐乐"] },
      "a": { "type": "range", "min": 2, "max": 8 },
      "b": { "type": "range", "min": 3, "max": 10 },
      "c": { "type": "range", "min": 1, "max": 6 },
      "d": { "type": "range", "min": 2, "max": 8 },
      "money": { "type": "range", "min": 50, "max": 100, "step": 10 }
    },
    "constraints": [
      { "check": "a * b + c * d < money", "msg": "总花费应小于付款金额" },
      { "check": "money - (a * b + c * d) >= 1", "msg": "至少找回1元" }
    ],
    "answer": {
      "type": "steps",
      "unit": "元",
      "steps": [
        { "label": "笔记本总价", "expr": "a * b", "unit": "元" },
        { "label": "笔总价", "expr": "c * d", "unit": "元" },
        { "label": "一共花费", "expr": "a * b + c * d", "unit": "元" },
        { "label": "应找回", "expr": "money - (a * b + c * d)", "unit": "元" }
      ]
    },
    "source": "21世纪教育网·三下·小数加减应用题"
  },
  {
